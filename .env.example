# Remote Key Manager Environment Variables

# API Key for authentication (REQUIRED - MUST be set in production)
# Generate: openssl rand -hex 32
API_KEY=your-super-secret-api-key-change-this

# Server Port
PORT=3001

# Database Path (SQLite)
DB_PATH=./passkeys.db

# Allowed CORS origins (comma-separated)
# Dev: http://localhost:3000
# Prod: https://agentpad.vercel.app,https://agentpad-production.vercel.app
CORS_ORIGINS=http://localhost:3000,https://agentpad.vercel.app

# Node Environment
NODE_ENV=development

# Rate Limiting (optional overrides)
# RATE_LIMIT_MAX=100
# RATE_LIMIT_WINDOW=60000
